@page "/languages"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject UserSession Session
@inject NavigationManager Nav

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded-3">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Thống kê Hệ thống</h3>
            <small class="text-muted">Tổng quan quy mô dữ liệu và tiến độ dịch thuật toàn cầu</small>
        </div>
        <div class="d-flex gap-3">
            <div class="stat-box bg-primary-subtle text-primary p-2 px-3 rounded-3 text-center border border-primary-subtle">
                <small class="d-block fw-bold text-uppercase" style="font-size: 0.65rem;">Tổng địa điểm</small>
                <span class="fs-5 fw-bold">@totalPois</span>
            </div>
            <div class="stat-box bg-success-subtle text-success p-2 px-3 rounded-3 text-center border border-success-subtle">
                <small class="d-block fw-bold text-uppercase" style="font-size: 0.65rem;">Ngôn ngữ hỗ trợ</small>
                <span class="fs-5 fw-bold">@languages.Count</span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm animate__animated animate__shakeX">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @errorMessage
        </div>
    }

    <div class="row g-4">
        @* Cột trái: Danh sách ngôn ngữ (Hệ thống) *@
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-translate me-2"></i>DANH MỤC NGÔN NGỮ</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light small fw-bold">
                                <tr>
                                    <th class="ps-4 py-3">NGÔN NGỮ</th>
                                    <th>MÃ</th>
                                    <th>GIỌNG ĐỌC (TTS)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (languages != null && languages.Any())
                                {
                                    @foreach (var lang in languages)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <span class="fs-4 me-2">@GetFlag(lang.Code)</span>
                                                    <span class="fw-bold text-dark">@lang.Name</span>
                                                </div>
                                            </td>
                                            <td><span class="badge bg-light text-primary border px-2">@lang.Code.ToUpper()</span></td>
                                            <td><code class="text-muted x-small">@lang.Voice</code></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted italic">Đang tải danh sách...</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* Cột phải: Biểu đồ tiến độ dịch thuật *@
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart-fill me-2"></i>TIẾN ĐỘ HOÀN THIỆN NỘI DUNG</h6>
                    <i class="bi bi-arrow-repeat cursor-pointer" @onclick="OnInitializedAsync"></i>
                </div>
                <div class="card-body p-4 bg-light">
                    @if (stats == null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-grow text-primary" role="status"></div>
                            <p class="mt-3 text-muted">Đang phân tích dữ liệu thời gian thực...</p>
                        </div>
                    }
                    else if (!stats.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-clipboard-x display-4 text-light"></i>
                            <p class="text-muted mt-2">Chưa có dữ liệu bản dịch để thống kê.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var stat in stats)
                        {
                            var percent = totalPois > 0 ? (stat.Count * 100 / totalPois) : 0;
                            <div class="mb-4 bg-white p-3 rounded-3 shadow-sm border-start border-4 @GetBorderColor(percent)">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div>
                                        <span class="fs-5 me-1">@GetFlag(stat.Language)</span>
                                        <span class="fw-bold text-dark text-uppercase">@stat.Language</span>
                                        <small class="text-muted ms-2">(@stat.Count / @totalPois POI)</small>
                                    </div>
                                    <span class="badge @GetColor(percent) rounded-pill shadow-sm">@percent% Hoàn tất</span>
                                </div>
                                <div class="progress" style="height: 10px; border-radius: 5px; background-color: #eee;">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated @GetColor(percent)" 
                                         role="progressbar" style="width: @percent%"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="card-footer bg-white border-0 py-3 text-center">
                    <small class="text-muted italic"><i class="bi bi-info-circle me-1"></i> % hoàn thành dựa trên tổng số POI đang hoạt động trên hệ thống.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .shadow-sm { box-shadow: 0 .125rem .25rem rgba(0,0,0,.075)!important; }
    .card { transition: transform 0.2s; }
    .progress-bar { transition: width 1s ease-in-out; }
    .stat-box { min-width: 100px; }
    .italic { font-style: italic; }
    .cursor-pointer { cursor: pointer; }
</style>

@code {
    private int totalPois = 0;
    private List<LangStat>? stats;
    private List<LangInfo> languages = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        
        var http = HttpFactory.CreateClient("WebAPI");
        errorMessage = null;

        try {
            // 1. Tải danh sách ngôn ngữ
            var dbLangs = await http.GetFromJsonAsync<List<SupportedLanguageDto>>("/api/Language");
            if (dbLangs != null) 
                languages = dbLangs.Select(l => new LangInfo(l.Code, l.Name, l.Voice)).ToList();

            // 2. Tải danh sách POI
            var pois = await http.GetFromJsonAsync<List<PoiDto>>("/api/Poi");
            totalPois = pois?.Count ?? 0;

            // 3. Tải thống kê
            var result = await http.GetFromJsonAsync<StatsResponse>("/api/Translation/stats");
            stats = result?.ByLanguage ?? new();
        }
        catch (Exception ex) {
            errorMessage = "❌ Lỗi kết nối: " + ex.Message;
            if (languages == null) languages = new();
            if (stats == null) stats = new();
        }
    }

    private string GetFlag(string code) => code.ToLower() switch {
        "vi" => "🇻🇳", "en" => "🇺🇸", "zh" => "🇨🇳", "ja" => "🇯🇵", "ko" => "🇰🇷", "fr" => "🇫🇷", _ => "🌐"
    };

    private string GetColor(int percent) => percent switch {
        < 30 => "bg-danger",
        < 80 => "bg-warning text-dark",
        _ => "bg-success"
    };

    private string GetBorderColor(int percent) => percent switch {
        < 30 => "border-danger",
        < 80 => "border-warning",
        _ => "border-success"
    };

    public record LangInfo(string Code, string Name, string Voice);
    public class LangStat { public string Language { get; set; } = ""; public int Count { get; set; } }
    public class PoiDto { public int Id { get; set; } }
    public class SupportedLanguageDto {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Voice { get; set; } = "";
    }
    public class StatsResponse {
        public int Total { get; set; }
        public List<LangStat> ByLanguage { get; set; } = new();
    }
}