@page "/languagesetting"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded-3">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-gear-wide-connected me-2"></i>Cấu hình Ngôn ngữ</h3>
            <small class="text-muted">Quản lý các ngôn ngữ và giọng đọc (TTS) được hỗ trợ trên hệ thống</small>
        </div>
        <span class="badge bg-primary rounded-pill px-3 py-2">Tổng số: @languages.Count</span>
    </div>

    <div class="card border-0 shadow-sm mb-4 animate__animated animate__fadeInDown">
        <div class="card-header bg-dark text-white fw-bold py-3">
            <i class="bi bi-plus-circle me-2"></i>THÊM NGÔN NGỮ MỚI
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label fw-bold">Mã (Code)</label>
                    <input @bind="newLang.Code" class="form-control border-0 shadow-sm" placeholder="vd: vi, en, zh..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Tên hiển thị</label>
                    <input @bind="newLang.Name" class="form-control border-0 shadow-sm" placeholder="vd: Tiếng Việt" />
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold">Giọng đọc (Voice Name)</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-0"><i class="bi bi-megaphone"></i></span>
                        <input @bind="newLang.VoiceName" class="form-control border-0" placeholder="vd: vi-VN-Standard-A" />
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100 py-2 fw-bold shadow" @onclick="AddLanguage" disabled="@isProcessing">
                        @if (isProcessing) { 
                            <span class="spinner-border spinner-border-sm me-1"></span> 
                        } else { 
                            <i class="bi bi-cloud-arrow-up-fill me-1"></i> <span>Thêm</span> 
                        }
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="alert alert-danger border-0 mt-3 mb-0 py-2 shadow-sm animate__animated animate__shakeX">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMsg
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden animate__animated animate__fadeInUp">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-primary text-white text-uppercase small">
                    <tr>
                        <th class="ps-4 py-3" style="width: 15%">Mã Code</th>
                        <th style="width: 25%">Tên ngôn ngữ</th>
                        <th>Giọng đọc (Voice Name)</th>
                        <th class="text-center pe-4" style="width: 15%">Hành động</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (languages.Any())
                    {
                        @foreach (var lang in languages)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 fw-bold">
                                        @lang.Code.ToUpper()
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@lang.Name</div>
                                </td>
                                <td>
                                    <code class="bg-light p-2 rounded text-secondary small border">
                                        <i class="bi bi-soundwave me-1"></i> @(string.IsNullOrEmpty(lang.VoiceName) ? "Chưa cấu hình giọng" : lang.VoiceName)
                                    </code>
                                </td>
                                <td class="text-center pe-4">
                                    <button class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm" @onclick="() => DeleteLanguage(lang.Id)">
                                        <i class="bi bi-trash3-fill"></i> Xóa
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-folder-x display-4 text-light"></i>
                                <p class="text-muted mt-2 small">Hệ thống chưa có ngôn ngữ nào. Hãy thêm một mã như 'vi' hoặc 'en'.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th { font-weight: 700; letter-spacing: 0.5px; border: none; }
    .table tbody tr { transition: background 0.2s; }
    .table tbody tr:hover { background-color: #f8faff; }
    .animate__animated { animation-duration: 0.5s; }
    .input-group-text { color: #0d6efd; }
</style>

@code {
    private List<SupportedLanguage> languages = new();
    private SupportedLanguage newLang = new();
    private bool isProcessing = false;
    private string? errorMsg;

    protected override async Task OnInitializedAsync() => await LoadLanguages();

    private async Task LoadLanguages()
    {
        try {
            var http = HttpFactory.CreateClient("WebAPI");
            languages = await http.GetFromJsonAsync<List<SupportedLanguage>>("api/Language") ?? new();
        } catch (Exception ex) { errorMsg = $"Lỗi tải dữ liệu: {ex.Message}"; }
    }

    private async Task AddLanguage()
    {
        if (string.IsNullOrWhiteSpace(newLang.Code) || string.IsNullOrWhiteSpace(newLang.Name))
        {
            errorMsg = "Vui lòng nhập đầy đủ Mã và Tên ngôn ngữ.";
            return;
        }

        isProcessing = true;
        errorMsg = null;
        try {
            var http = HttpFactory.CreateClient("WebAPI");
            var res = await http.PostAsJsonAsync("api/Language", newLang);
            if (res.IsSuccessStatusCode) {
                newLang = new();
                await LoadLanguages();
            } else { errorMsg = "Không thể thêm. Có thể mã bị trùng hoặc lỗi Server."; }
        } catch (Exception ex) { errorMsg = "Lỗi kết nối: " + ex.Message; }
        finally { isProcessing = false; }
    }

    private async Task DeleteLanguage(int id)
    {
        try {
            var http = HttpFactory.CreateClient("WebAPI");
            await http.DeleteAsync($"api/Language/{id}");
            await LoadLanguages();
        } catch (Exception ex) { errorMsg = "Lỗi khi xóa: " + ex.Message; }
    }

    public class SupportedLanguage
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string VoiceName { get; set; } = "";
    }
}