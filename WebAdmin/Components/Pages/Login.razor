@page "/login"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject UserSession Session

<div class="d-flex justify-content-center mt-5">
    <div class="card p-4" style="width:400px">
        <h4 class="text-center mb-4">Đăng nhập Admin</h4>

        @if (errorMsg != null)
        {
            <div class="alert alert-danger">@errorMsg</div>
        }

        <div class="mb-3">
            <label>Tài khoản</label>
            <input class="form-control" @bind="username"/>
        </div>
        <div class="mb-3">
            <label>Mật khẩu</label>
            <input class="form-control" type="password" @bind="password"/>
        </div>
        <button class="btn btn-primary w-100" @onclick="DoLogin">Đăng nhập</button>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string? errorMsg;

    private async Task DoLogin()
    {
        errorMsg = null;
        var http = HttpFactory.CreateClient("WebAPI");

        var response = await http.PostAsJsonAsync("/api/Auth/login", new
        {
            username, password
        });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResult>();
            Session.Username = result!.Username;
            Session.FullName = result.FullName;
            Session.Role = result.Role;
            Session.PoiId = result.PoiId;
            Nav.NavigateTo("/pois", forceLoad: false);
        }
        else
        {
            var err = await response.Content.ReadFromJsonAsync<ErrorResult>();
            errorMsg = err?.Message ?? "Đăng nhập thất bại";
        }
    }

    public class LoginResult
    {
        public string Username { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Role { get; set; } = "";
        public int? PoiId { get; set; }
    }

    public class ErrorResult
    {
        public string? Message { get; set; }
    }
}