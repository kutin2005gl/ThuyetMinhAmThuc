@page "/users"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject UserSession Session
@inject NavigationManager Nav

<h3>Quản lý tài khoản</h3>

@if (!Session.IsAdmin)
{
    <div class="alert alert-danger">Bạn không có quyền truy cập trang này.</div>
    return;
}

<div class="card p-3 mb-3">
    <h5>Tạo tài khoản mới</h5>
    <div class="mb-2">
        <label>Tài khoản</label>
        <input class="form-control" @bind="form.Username"/>
    </div>
    <div class="mb-2">
        <label>Mật khẩu</label>
        <input class="form-control" type="password" @bind="form.Password"/>
    </div>
    <div class="mb-2">
        <label>Họ tên</label>
        <input class="form-control" @bind="form.FullName"/>
    </div>
    <div class="mb-2">
        <label>Vai trò</label>
        <select class="form-select" @bind="form.Role">
            <option value="Admin">Admin</option>
            <option value="Staff">Staff (Chủ quầy)</option>
        </select>
    </div>
    @if (form.Role == "Staff")
    {
        <div class="mb-2">
            <label>Quầy phụ trách</label>
            <select class="form-select" @bind="form.PoiId">
                <option value="">-- Chọn quầy --</option>
                @if (pois != null)
                {
                    @foreach (var poi in pois)
                    {
                        <option value="@poi.Id">@poi.Name</option>
                    }
                }
            </select>
        </div>
    }
    <button class="btn btn-success" @onclick="CreateUser">Tạo tài khoản</button>
</div>

@if (message != null)
{
    <div class="alert alert-info">@message</div>
}

@code {
    private List<PoiDto>? pois;
    private string? message;
    private RegisterForm form = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn || !Session.IsAdmin)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var http = HttpFactory.CreateClient("WebAPI");
        pois = await http.GetFromJsonAsync<List<PoiDto>>("/api/Poi");
    }

    private async Task CreateUser()
    {
        var http = HttpFactory.CreateClient("WebAPI");
        var response = await http.PostAsJsonAsync("/api/Auth/register", new
        {
            form.Username,
            form.Password,
            form.FullName,
            form.Role,
            PoiId = form.PoiId == 0 ? (int?)null : form.PoiId
        });

        message = response.IsSuccessStatusCode
            ? "Tạo tài khoản thành công!"
            : "Lỗi: Tài khoản đã tồn tại";

        form = new RegisterForm();
    }

    public class PoiDto { public int Id { get; set; } public string Name { get; set; } = ""; }

    public class RegisterForm
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Role { get; set; } = "Staff";
        public int PoiId { get; set; } = 0;
    }
}