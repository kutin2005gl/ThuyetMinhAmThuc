@page "/users"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject UserSession Session
@inject NavigationManager Nav

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded-3">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-people-fill me-2"></i>Quản lý Hệ thống</h3>
            <small class="text-muted">Quản lý tài khoản Admin và nhân viên phụ trách quầy (Staff)</small>
        </div>
        <span class="badge bg-dark rounded-pill px-3 py-2">Tổng số: @(users?.Count ?? 0)</span>
    </div>

    @if (!Session.IsAdmin)
    {
        <div class="alert alert-danger border-0 shadow-sm animate__animated animate__headShake">
            <i class="bi bi-shield-lock-fill me-2"></i> <strong>Cảnh báo:</strong> Bạn không có quyền truy cập vào khu vực quản trị viên.
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white fw-bold py-3">
                        <i class="bi bi-person-plus-fill me-2"></i>TẠO TÀI KHOẢN MỚI
                    </div>
                    <div class="card-body p-4 bg-light">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên đăng nhập</label>
                            <input class="form-control border-0 shadow-sm" @bind="form.Username" placeholder="Nhập username..." />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <input class="form-control border-0 shadow-sm" type="password" @bind="form.Password" placeholder="••••••••" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và Tên</label>
                            <input class="form-control border-0 shadow-sm" @bind="form.FullName" placeholder="Nguyễn Văn A..." />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Vai trò hệ thống</label>
                            <select class="form-select border-0 shadow-sm" @bind="form.Role">
                                <option value="Staff">Nhân viên (Staff)</option>
                                <option value="Admin">Quản trị viên (Admin)</option>
                            </select>
                        </div>

                        @if (form.Role == "Staff")
                        {
                            <div class="mb-3 animate__animated animate__fadeInDown">
                                <label class="form-label fw-bold text-primary">Quầy phụ trách (POI)</label>
                                <select class="form-select border-primary-subtle shadow-sm" @bind="form.PoiId">
                                    <option value="0">-- Chọn địa điểm phụ trách --</option>
                                    @if (pois != null)
                                    {
                                        @foreach (var poi in pois)
                                        {
                                            <option value="@poi.Id">@poi.Name</option>
                                        }
                                    }
                                </select>
                                <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle"></i> Staff chỉ có quyền sửa nội dung tại quầy này.</small>
                            </div>
                        }

                        <button class="btn btn-success w-100 py-2 fw-bold shadow mt-3" @onclick="CreateUser">
                            <i class="bi bi-check-circle-fill me-2"></i>Xác nhận tạo
                        </button>
                    </div>
                </div>

                @if (message != null)
                {
                    <div class="alert @(message.Contains("✅") ? "alert-success" : "alert-danger") border-0 shadow-sm mt-3 animate__animated animate__fadeIn">
                        @message
                    </div>
                }
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-dark text-white text-uppercase small">
                                <tr>
                                    <th class="ps-4 py-3">Người dùng</th>
                                    <th>Vai trò</th>
                                    <th>Quầy phụ trách</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center pe-4">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white">
                                @if (users == null)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">Đang tải danh sách...</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var user in users)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle me-3 bg-primary-subtle text-primary fw-bold">
                                                        @user.Username.Substring(0, 1).ToUpper()
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold text-dark">@user.FullName</div>
                                                        <div class="small text-muted">@@@user.Username</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary") rounded-pill px-3">
                                                    @user.Role
                                                </span>
                                            </td>
                                            <td>
                                                @if (user.Role == "Admin")
                                                {
                                                    <span class="text-muted italic small">Toàn quyền hệ thống</span>
                                                }
                                                else
                                                {
                                                    <span class="text-dark fw-medium">
                                                        <i class="bi bi-geo-alt me-1 text-danger"></i>
                                                        @(pois?.FirstOrDefault(p => p.Id == user.PoiId)?.Name ?? "Chưa gán")
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (user.IsActive)
                                                {
                                                    <span class="text-success small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i> Hoạt động</span>
                                                }
                                                else
                                                {
                                                    <span class="text-danger small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i> Đã khóa</span>
                                                }
                                            </td>
                                            <td class="text-center pe-4">
                                                <button class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-success") px-3 rounded-pill fw-bold"
                                                        @onclick="() => ToggleUser(user.Id)">
                                                    @if (user.IsActive) { <i class="bi bi-lock-fill"></i> @(" Khóa") }
                                                    else { <i class="bi bi-unlock-fill"></i> @(" Mở khóa") }
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }
    .table thead th { font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px; border: none; }
    .table tbody tr:hover { background-color: #f8faff; }
    .animate__animated { animation-duration: 0.5s; }
    .shadow-sm { box-shadow: 0 .125rem .25rem rgba(0,0,0,.075)!important; }
</style>

@code {
    private List<UserDto>? users;
    private List<PoiDto>? pois;
    private string? message;
    private RegisterForm form = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn || !Session.IsAdmin)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try {
            var http = HttpFactory.CreateClient("WebAPI");
            pois = await http.GetFromJsonAsync<List<PoiDto>>("/api/Poi");
            await LoadUsers();
        } catch { message = "❌ Không thể kết nối đến máy chủ!"; }
    }

    private async Task LoadUsers()
    {
        var http = HttpFactory.CreateClient("WebAPI");
        users = await http.GetFromJsonAsync<List<UserDto>>("/api/Auth/users");
    }

    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(form.Username) || string.IsNullOrWhiteSpace(form.Password)) {
            message = "⚠️ Vui lòng nhập đầy đủ Tài khoản & Mật khẩu!";
            return;
        }

        var http = HttpFactory.CreateClient("WebAPI");
        var response = await http.PostAsJsonAsync("/api/Auth/register", new
        {
            form.Username,
            form.Password,
            form.FullName,
            form.Role,
            PoiId = form.PoiId == 0 ? (int?)null : form.PoiId
        });

        if (response.IsSuccessStatusCode) {
            message = "✅ Tạo tài khoản thành công!";
            form = new RegisterForm();
            await LoadUsers();
        } else {
            message = "❌ Lỗi: Tài khoản đã tồn tại hoặc dữ liệu không hợp lệ!";
        }
    }

    private async Task ToggleUser(int id)
    {
        var http = HttpFactory.CreateClient("WebAPI");
        await http.PutAsJsonAsync($"/api/Auth/users/{id}/toggle", new { });
        await LoadUsers();
    }

    public class UserDto {
        public int Id { get; set; }
        public string Username { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Role { get; set; } = "";
        public int? PoiId { get; set; }
        public bool IsActive { get; set; }
    }

    public class PoiDto {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    public class RegisterForm {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Role { get; set; } = "Staff";
        public int PoiId { get; set; } = 0;
    }
}