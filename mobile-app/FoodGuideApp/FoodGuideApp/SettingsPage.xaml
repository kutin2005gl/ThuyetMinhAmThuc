<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodGuideApp.SettingsPage"
             Title="Cài đặt">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="15">

			<Label Text="CÀI ĐẶT"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

			<Label Text="Chọn ngôn ngữ"
                   FontSize="18" />

			<Picker x:Name="languagePicker"
                    Title="Chọn ngôn ngữ">
				<Picker.ItemsSource>
					<x:Array Type="{x:Type x:String}">
						<x:String>vi</x:String>
						<x:String>en</x:String>
						<x:String>zh</x:String>
						<x:String>ja</x:String>
					</x:Array>
				</Picker.ItemsSource>
			</Picker>

			<Label Text="Bán kính geofence (mét)"
                   FontSize="18" />

			<Entry x:Name="radiusEntry"
                   Placeholder="Nhập bán kính, ví dụ 30"
                   Keyboard="Numeric" />

			<Button Text="Lưu cài đặt"
                    Clicked="OnSaveSettingsClicked" />

			<Label x:Name="statusLabel"
                   TextColor="Green"
                   FontSize="16" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>		